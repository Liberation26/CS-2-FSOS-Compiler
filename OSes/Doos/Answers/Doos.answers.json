{
  "OrynVersion": "1.0.7",
  "OsName": "Doos",
  "KernelName": "DoosKernel",
  "Target": "x64-elf",
  "DefaultBootMode": "long-mode",
  "VmProfile": "RunQemu",
  "VmDisplayMode": "Visual",
  "BuildMode": "Debug",
  "MandatoryKernelModules": [
    "Runtime",
    "Diagnostics",
    "Panic",
    "Cpu",
    "ManifestLoader"

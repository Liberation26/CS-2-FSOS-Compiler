{
  "OrynVersion": "1.0.4",
  "OsName": "Dsos",
  "KernelName": "DsosKernel",
  "Target": "x64-elf",
  "DefaultBootMode": "long-mode",
  "VmProfile": "RunQemu",
  "BuildMode": "Debug",
  "MandatoryKernelModules": [
    "Runtime",
    "Diagnostics",
    "Panic",
    "Cpu",
    "ManifestLoader"
  ],
  "DiagnosticsAlwaysEnabled": true,
  "PanicAlwaysEnabled": true,
  "UserSelectedModules": [
    "Memory"
  ]
}
